# AgentInvest Environment Variables
# Copy this file to .env and fill in your actual values

# Tavily API Key for web search functionality
TAVILY_API_KEY=your_tavily_api_key_here

# Google Cloud Project ID (usually found in your service account JSON)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# Redis Configuration (optional, defaults to localhost)
REDIS_URL=redis://localhost:6379

# Chart.js Source (optional, defaults to CDN)
CHARTJS_SRC=https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js

# Optional: Custom model configurations
# GEMINI_MODEL_NAME=gemini-2.0-flash
# GEMINI_TEMPERATURE=1
# GEMINI_MAX_TOKENS=8000
